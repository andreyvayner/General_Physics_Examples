   ],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.animation import FuncAnimation\n",
    "\n",
    "# -----------------------------\n",
    "# Parameters\n",
    "# -----------------------------\n",
    "L = 1.0                 # Length of the string\n",
    "A = 1.0                 # Amplitude\n",
    "n = 3                   # Harmonic number (n = 1, 2, 3, ...)\n",
    "f = 1.0                 # Frequency in Hz\n",
    "omega = 2 * np.pi * f   # Angular frequency\n",
    "\n",
    "# Spatial grid\n",
    "x = np.linspace(0, L, 1000)\n",
    "\n",
    "# Standing wave shape:\n",
    "# y(x, t) = A sin(n*pi*x/L) cos(omega*t)\n",
    "def standing_wave(x, t):\n",
    "    return A * np.sin(n * np.pi * x / L) * np.cos(omega * t)\n",
    "\n",
    "# -----------------------------\n",
    "# Figure setup\n",
    "# -----------------------------\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "line, = ax.plot(x, standing_wave(x, 0), lw=2)\n",
    "\n",
    "# Fixed ends\n",
    "ax.plot([0, L], [0, 0], 'ko', ms=6)\n",
    "\n",
    "ax.set_xlim(0, L)\n",
    "ax.set_ylim(-1.2 * A, 1.2 * A)\n",
    "ax.set_xlabel(\"Position along string\")\n",
    "ax.set_ylabel(\"Displacement\")\n",
    "ax.set_title(f\"Standing Wave with Two Fixed Ends (n = {n})\")\n",
    "ax.grid(True)\n",
    "\n",
    "time_text = ax.text(0.02, 0.92, '', transform=ax.transAxes)\n",
    "\n",
    "# -----------------------------\n",
    "# Animation update\n",
    "# -----------------------------\n",
    "def update(frame):\n",
    "    t = frame / 100.0\n",
    "    y = standing_wave(x, t)\n",
    "    line.set_ydata(y)\n",
    "    time_text.set_text(f\"t = {t:.2f} s\")\n",
    "    return line, time_text\n",
    "\n",
    "# Create animation\n",
    "ani = FuncAnimation(\n",
    "    fig,\n",
    "    update,\n",
    "    frames=400,\n",
    "    interval=20,\n",
    "    blit=True\n",
    ")\n",
    "\n",
    "plt.show()"
   ]
  }
 ],
